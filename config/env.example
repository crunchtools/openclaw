# OpenClaw environment file for systemd EnvironmentFile directive
# Copy to /srv/openclaw.crunchtools.com/config/env and fill in values
# chmod 600 /srv/openclaw.crunchtools.com/config/env
#
# SECURITY: This file contains secrets. Never commit to git.

# LLM Provider — Google Gemini (all tiers)
GOOGLE_AI_API_KEY=your_gemini_api_key_here

# MCP Server credentials (add as needed when expanding allowlist)
# RT_URL=https://rt.fatherlinux.com
# RT_USER=
# RT_PASSWORD=
# MEDIAWIKI_URL=https://learn.fatherlinux.com
# MEDIAWIKI_USER=
# MEDIAWIKI_PASSWORD=
# MCP_MEMORY_URL=https://memory.crunchtools.com
# MCP_MEMORY_TOKEN=
